                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  cm.sensitivity_level AS \"Mức độ\",\n  COUNT(*) AS \"Số cột\"\nFROM columns_metadata cm\nJOIN tables_metadata tm ON tm.table_id = cm.table_id\nWHERE cm.sensitivity_level <> 'NONE'\n  AND ('${selected_table}' = 'ALL_TABLES' OR tm.table_name = '${selected_table}')\nGROUP BY cm.sensitivity_level\nORDER BY\n  CASE cm.sensitivity_level\n    WHEN 'HIGH'   THEN 1\n    WHEN 'MEDIUM' THEN 2\n    WHEN 'LOW'    THEN 3\n    ELSE 4\n  END;"
                      },
                      "version": "v0"

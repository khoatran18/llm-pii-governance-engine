      "panel-5": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "postgres_uid"
                      },
                      "group": "postgres",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  pal.executed_at AS \"Thời gian\",\n  pal.user_role AS \"Role\",\n  pal.target_table AS \"Bảng\",\n  col_item->>'sensitivity_level' AS \"Sensitivity Level\",\n  ap.masking_rule AS \"Masking Rule\",\n  COUNT(*) AS \"Số cột\",\n  string_agg(col_item->>'column_name', ', ' ORDER BY col_item->>'column_name') AS \"Các cột bị tác động\"\nFROM policy_engine_audit_logs pal\nCROSS JOIN jsonb_array_elements(pal.context_details->'accessed_columns') AS col_item\nLEFT JOIN access_policies ap\n  ON ap.role_name = pal.user_role\n  AND ap.sensitivity_level = col_item->>'sensitivity_level'\n  AND ('${selected_table}' = 'ALL_TABLES' OR pal.target_table = '${selected_table}')\nGROUP BY\n  pal.log_id,\n  pal.executed_at,\n  pal.user_role,\n  pal.target_table,\n  col_item->>'sensitivity_level',\n  ap.masking_rule\nORDER BY\n  pal.executed_at DESC,\n  CASE col_item->>'sensitivity_level'\n    WHEN 'HIGH'   THEN 1\n    WHEN 'MEDIUM' THEN 2\n    WHEN 'LOW'    THEN 3\n    ELSE 4\n  END\nLIMIT 300;"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
